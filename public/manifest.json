{
  "manifest_version": 3,
  "name": "HireTrack",
  "version": "1.0.0",
  "description": "Track internships manually and auto-log from confirmation pages",
  "permissions": ["storage", "tabs"],
  "icons": {
    "248": "logo.png"
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "HireTrack",
    "default_popup": "index.html"
  }
}